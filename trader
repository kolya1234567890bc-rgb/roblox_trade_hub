<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Roblox Mega Hub 2026</title>
    <style>
        :root {
            --primary: #e94560;
            --secondary: #4db8ff;
            --dark: #0b0e14;
            --card: #1a1a2e;
            --success: #00ff7f;
            --gold: #ffd700;
        }

        body { font-family: 'Segoe UI', sans-serif; background: var(--dark); color: white; margin: 0; padding-bottom: 80px; }
        .page { display: none; padding: 15px; animation: fadeIn 0.4s ease; }
        .active { display: block; }
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

        /* HEADER & ECONOMY */
        header { background: #16213e; padding: 15px; border-bottom: 2px solid var(--primary); sticky; top: 0; z-index: 100; }
        .economy-bar { display: flex; justify-content: space-around; background: #0f3460; padding: 8px; font-size: 0.8em; border-radius: 10px; margin-top: 10px; }
        .token { color: var(--gold); font-weight: bold; }
        .gems { color: var(--secondary); font-weight: bold; }

        /* QUESTS */
        .quest-card { background: var(--card); border-radius: 15px; padding: 15px; margin-bottom: 12px; border: 1px solid #333; position: relative; }
        .quest-reward { color: var(--gold); font-weight: bold; font-size: 0.9em; }
        .quest-status { float: right; font-size: 0.7em; background: #333; padding: 4px 8px; border-radius: 5px; }

        /* GAMES & TRADES */
        .games-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 15px; }
        .game-item { background: var(--card); padding: 15px; border-radius: 12px; text-align: center; border: 1px solid #333; cursor: pointer; }
        .trade-item { background: var(--card); padding: 15px; border-radius: 15px; margin-bottom: 10px; display: flex; justify-content: space-between; align-items: center; }

        /* NAV */
        .nav { position: fixed; bottom: 0; width: 100%; background: #16213e; display: flex; justify-content: space-around; padding: 12px 0; border-top: 2px solid #333; }
        .nav-btn { background: none; border: none; color: #888; font-size: 0.7em; cursor: pointer; }
        .nav-btn.active-nav { color: var(--primary); }
        .btn { background: var(--primary); border: none; color: white; padding: 10px; border-radius: 8px; width: 100%; font-weight: bold; cursor: pointer; }
        .btn:disabled { background: #555; cursor: not-allowed; }
    </style>
</head>
<body>

<header>
    <div style="text-align: center; font-weight: bold;">RBX TRADE PLATFORM</div>
    <div class="economy-bar">
        <span>🪙 <span id="token-balance">5</span> T-Tokens</span>
        <span>💎 <span id="gem-balance">1500</span> Gems</span>
    </div>
</header>

<div id="home" class="page active">
    <h3>🎮 Игры для трейда</h3>
    <div class="games-grid" id="games-list">
        </div>
</div>

<div id="quests" class="page">
    <h3>📋 Ежедневные задания</h3>
    <div id="quests-container">
        <div class="quest-card">
            <b>Посмотреть 5 трейдов</b><br>
            <span class="quest-reward">+1 T-Token</span>
            <button class="btn" style="width: auto; float: right; margin-top: -10px;" onclick="completeQuest(this, 1, 0)">Выполнить</button>
        </div>
        <div class="quest-card">
            <b>Пригласить друга</b><br>
            <span class="quest-reward">+3 T-Tokens, +500 Gems</span>
            <button class="btn" style="width: auto; float: right; margin-top: -10px;" onclick="completeQuest(this, 3, 500)">Выполнить</button>
        </div>
        <div class="quest-card">
            <b>Оформить трейд в Blox Fruits</b><br>
            <span class="quest-reward">+1 T-Token</span>
            <button class="btn" style="width: auto; float: right; margin-top: -10px;" onclick="completeQuest(this, 1, 0)">Выполнить</button>
        </div>
    </div>
</div>

<div id="profile" class="page">
    <h3>👤 Мой профиль</h3>
    <div class="quest-card">
        <b>Ник:</b> <span id="u-nick">Трейдер_Void</span><br>
        <b>Ранг:</b> <span style="color:var(--secondary)">Новичок</span>
    </div>
    <p style="font-size: 0.8em; color: #888;">* Трейд-токены нужны для подтверждения сделок. Каждая сделка стоит 1 T-Token.</p>
</div>

<div id="game-page" class="page">
    <button onclick="showPage('home')" style="background:none; border:none; color:var(--primary); font-weight:bold;">← Назад</button>
    <h2 id="current-game">Игра</h2>
    <div id="items-container"></div>
</div>

<div class="nav">
    <button class="nav-btn active-nav" onclick="showPage('home', this)">🏠<br>Главная</button>
    <button class="nav-btn" onclick="showPage('quests', this)">🎯<br>Задания</button>
    <button class="nav-btn" onclick="showPage('profile', this)">👤<br>Профиль</button>
</div>

<script>
    let tokens = 5;
    let gems = 1500;

    const gameNames = [
        "Blox Fruits", "Pet Sim 99", "King Legacy", "Doors", "Adopt Me", 
        "MM2", "Bee Swarm", "BedWars", "Brookhaven", "Fruit B.", 
        "Blade Ball", "All Star TD", "Sol’s RNG", "Anime Defenders", "Dress To Impress"
    ];

    // Генерация игр
    const grid = document.getElementById('games-list');
    gameNames.forEach(game => {
        grid.innerHTML += `
            <div class="game-item" onclick="openGame('${game}')">
                <span style="font-size:1.5em; display:block;">🎮</span>
                ${game}
            </div>
        `;
    });

    function showPage(id, btn) {
        document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
        document.getElementById(id).classList.add('active');
        if(btn) {
            document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active-nav'));
            btn.classList.add('active-nav');
        }
    }

    function openGame(name) {
        document.getElementById('current-game').innerText = name;
        const container = document.getElementById('items-container');
        container.innerHTML = '';
        for(let i=1; i<=3; i++) {
            container.innerHTML += `
                <div class="trade-item">
                    <div><b>Редкий предмет #${i}</b><br><span style="color:#888">Цена: 1 T-Token</span></div>
                    <button class="btn" style="width:auto;" onclick="makeTrade()">ТРЕЙД</button>
                </div>
            `;
        }
        showPage('game-page');
    }

    function makeTrade() {
        if(tokens >= 1) {
            tokens--;
            updateEconomy();
            alert('Сделка оформлена! Списан 1 T-Token.');
        } else {
            alert('Недостаточно T-Tokens! Выполняй задания, чтобы получить еще.');
            showPage('quests');
        }
    }

    function completeQuest(btn, tAdd, gAdd) {
        tokens += tAdd;
        gems += gAdd;
        updateEconomy();
        btn.innerText = "Готово ✓";
        btn.disabled = true;
        btn.style.background = "#28a745";
        alert(`Награда получена: +${tAdd} Токенов!`);
    }

    function updateEconomy() {
        document.getElementById('token-balance').innerText = tokens;
        document.getElementById('gem-balance').innerText = gems;
    }
</script>

</body>
</html>

